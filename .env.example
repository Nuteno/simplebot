# Токен Telegram‑бота от @BotFather
TELEGRAM_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN

# Разрешённые пользователи (Telegram user_id). Несколько ID — через запятую.
# Сначала читается ALLOWED_USER_IDS; если пусто — ALLOWED_USER_ID (в нём тоже можно перечислить через запятую).
ALLOWED_USER_IDS=111111111,831967222
# ALLOWED_USER_ID=111111111
# ALLOWED_USER_ID=111111111,222222222

# VPN‑ключи для разных стран (vless://... или vmess://...)
VPN_KEY_RUSSIA=vless://...
VPN_KEY_NETHERLANDS=vless://...
VPN_KEY_UAE=vless://...
VPN_KEY_TURKEY=vless://...
VPN_KEY_SINGAPORE=vless://...
VPN_KEY_KAZAKHSTAN=vless://...
